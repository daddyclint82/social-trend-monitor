.env.example

Environment variables the project reads at runtime. Copy to .env (which
is gitignored) and fill in your own values.

# X (Twitter) API v2 — required to enable X trends discovery.
# Get yours at https://developer.x.com/en/portal
# X killed the free tier in 2023. Basic plan starts at $100/mo.
X_BEARER_TOKEN=

# Facebook Graph API — JSON map of page_id -> page access token.
# Only needed if you want to read posts from your own Facebook pages.
# FB_PAGE_TOKENS={"1234567890":"EAAxxxxxxx"}

# LLM (optional, for format extraction)
# Set STM_LLM_ENABLED=true to enable format extraction
# Requires Ollama running locally: https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ----- New in v0.3 (opt-in) -----

# Reddit OAuth (ADR-0011)
# Create a "script" app at https://www.reddit.com/prefs/apps
# The script-type app gives free access to public listings, 100 req/min.
# Set BOTH the client_id and client_secret. Then enable in config:
#   collectors.reddit.enabled: true
REDDIT_CLIENT_ID=
REDDIT_SECRET=

# Apify (ADR-0012)
# Free tier = $5/month. Create account at https://apify.com
# Generate an API token under Settings > Integrations.
# Then enable in config:
#   collectors.apify.enabled: true
# The collector enforces a monthly cap and per-cycle cap to stay
# safely under the $5 free tier.
APIFY_TOKEN=
